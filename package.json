{
  "name": "pokebox",
  "version": "1.0.0-RC1",
  "private": true,
  "description": "Vue 3 + Three.js Pokemon card viewer with real-time holographic effects and head tracking",
  "author": "Sergej Lopatkin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/selop/pokebox.git"
  },
  "homepage": "https://pokebox.lopatkin.net",
  "bugs": {
    "url": "https://github.com/selop/pokebox/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run --exclude 'src/data/__tests__/asset-integrity.test.ts'",
    "test:assets": "vitest run src/data/__tests__/asset-integrity.test.ts",
    "test:shader": "vitest run shader",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/face_detection": "^0.4.1646425229",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-zone": "^2.5.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation": "^0.212.0",
    "@opentelemetry/instrumentation-document-load": "^0.57.0",
    "@opentelemetry/instrumentation-fetch": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-trace-web": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "pinia": "^3.0.4",
    "three": "^0.182.0",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.10.9",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.42.0",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-vue": "~10.7.0",
    "jiti": "^2.6.1",
    "jsdom": "^25.0.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.42.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-glsl": "^1.5.5",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
