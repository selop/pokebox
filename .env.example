# Base URL for card set assets (fronts, holo-masks, etch-foils, set JSON).
# Leave empty to serve from public/ (local development).
# Set to /assets/ for production (served from mounted SSD volume via Nginx).
VITE_ASSET_BASE_URL=
# OpenTelemetry collector endpoint for tracing asset load timing between
# card storage and the app. Optional — not required for local development.
VITE_OTEL_COLLECTOR_URL=http://localhost:4318
